# 아임웹 REST API 연동용
# 실제 값은 여기에 넣지 마시고, `backend/.env`를 따로 생성해서 넣어주세요(보안).

IMWEB_API_KEY=your_api_key
IMWEB_API_SECRET=your_secret_key

# 필요 시 변경 (기본값은 그대로 사용 가능)
# IMWEB_API_BASE=https://api.imweb.me

# 쿠폰 발급(issued) 요청 설정
# iMweb에서 실제로 사용하는 endpoint/path/필드명이 문서/버전에 따라 다를 수 있어 env로 조절합니다.
IMWEB_COUPON_ISSUE_PATH=/v2/shop/coupons/issue
IMWEB_COUPON_ISSUE_MEMBER_KEY=memberId
IMWEB_COUPON_ISSUE_COUPON_CODE_KEY=couponCode
IMWEB_API_VERSION=latest

